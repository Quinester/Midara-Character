{
  "source": "Tabletop Simulator mod: Middara: Unintentional Malum - Act 1 (workshop id 2016593204)",
  "abilities": [
    {
      "name": "Banished Knowledge",
      "discipline": "Assemblage",
      "tier": 1,
      "description": "Exhaust: An ally within SOI Gains Haste, Reduce the SP cost of this Discipline by 1 if the target is an ally other than yourself. (\"There is safety in not knowing.\")"
    },
    {
      "name": "Euthanasia",
      "discipline": "Assemblage",
      "tier": 1,
      "description": "Cast a Spell 6. Inflict Wilt and deal 4 Magic DMG. Then, if the target was already Inflicted with Wilt, Inflict Condemn. If they were already Inflicted with both Condemn and Wilt, roll the Black. If a Skull is rolled, the target is Defeated."
    },
    {
      "name": "Familiar",
      "discipline": "Assemblage",
      "tier": 1,
      "description": "Passive: After learning this Discipline, choose a Familiar and place it face up next to your Adventurer card. Your Familiar cannot be changed."
    },
    {
      "name": "Forebode",
      "discipline": "Assemblage",
      "tier": 1,
      "description": "Exhaust: At any time, re-roll a roll you made or that was made against you. Limited by your highest Lvl Assemblage Discipline. LVL 1+: Dodge rolls or Skill Check rolls. LVL 2+: Spell Casting rolls. LVL 3+: Conviction rolls or Attack rolls. LVL 4+: Any rolls"
    },
    {
      "name": "Last Laugh",
      "discipline": "Assemblage",
      "tier": 1,
      "description": "Passive: If you or a Loyal Esper is Defeated, the figure that dealt the Damage is dealt their 2 Conviction Dice worth of Magic DMG. Exhaust: When you or a Loyal Esper is dealt Damage by an opponent, you may deal the source of that Damage 2 Irreducible DMG."
    },
    {
      "name": "Perfect Love",
      "discipline": "Assemblage",
      "tier": 1,
      "description": "Exhaust: Before an ally within SOI would Determine Damage from an Attack made against them, or Resolve the Spell's Effect from a Spell made against them, Redirect to yourself or a Loyal Esper. (\"There is no fear in love.\")"
    },
    {
      "name": "Sanctuary",
      "discipline": "Assemblage",
      "tier": 1,
      "description": "Exhaust: At any time, an ally within SOI may Dodge. (\"Here there is safety.\")"
    },
    {
      "name": "BFF",
      "discipline": "Assemblage",
      "tier": 2,
      "description": "Exhaust: At any time, when making an Attack, you or a Loyal Esper you've Summoned Gains the following: FU: Move 3 spaces without provoking Break Attacks, then make a ATK against a different target."
    },
    {
      "name": "Conduit Summoning",
      "discipline": "Assemblage",
      "tier": 2,
      "description": "Passive: Any time an opponent is Defeated within SOI, Earn their Conduit card. 1 SP: At any time, replace your Adventurer card with a Conduit card that you have Earned. Or, replace your current Conduit with your Adventurer card."
    },
    {
      "name": "Fortune Telling",
      "discipline": "Assemblage",
      "tier": 2,
      "description": "Per Encounter: After a figure within your SOI has rolled for any reason, choose the result of any single die except the Black. (\"Fortune, good night; smile once more, turn thy wheel.\")"
    },
    {
      "name": "Imposed Paradigm",
      "discipline": "Assemblage",
      "tier": 2,
      "description": "Cast a Spell 6. Swap places with the target. (\"A lie told often enough becomes the truth.\")"
    },
    {
      "name": "Possession",
      "discipline": "Assemblage",
      "tier": 2,
      "description": "Exhaust: A Loyal Esper within SOI makes a ATK or you may spend 1 SP and another ally within SOI makes a ATK instead. (\"Let us end this debate! There is such thing as free will, and I shall take yours as my own.\")"
    },
    {
      "name": "Ruination",
      "discipline": "Assemblage",
      "tier": 2,
      "description": "Cast a Spell 6 against up to 2 different opponents within SOI. Reduce the SP cost of this Discipline by 1 if all targets of this Discipline have an Effect. Roll your Casting die, deal Magic DMG equal to the result. (\"Ruin attends the wicked.\")"
    },
    {
      "name": "Summoning",
      "discipline": "Assemblage",
      "tier": 2,
      "description": "Per Encounter: Summon a Loyal Esper within your SOI. Then, Gain 1 Summon token. Passive: At anytime, Discard a Summon token to reduce any non-irreducible Damage being dealt to a Loyal Esper you control by 2."
    },
    {
      "name": "Exalted Summoning",
      "discipline": "Assemblage",
      "tier": 3,
      "description": "Per Encounter: Choose an Exalted Esper and use its Ability within SOI."
    },
    {
      "name": "Friends with Benefits",
      "discipline": "Assemblage",
      "tier": 3,
      "description": "Passive: When you use the Discipline Summoning, Gain 1 additional Summon token. Loyal Espers you Summon Gain +1 Health."
    },
    {
      "name": "Helping Hands",
      "discipline": "Assemblage",
      "tier": 3,
      "description": "Passive: You may equip an additional Consumable and Relic. Exhaust: Move up to 2 spaces. Gain Flight during this movement."
    },
    {
      "name": "Resonance",
      "discipline": "Assemblage",
      "tier": 3,
      "description": "FU: Use an un-flipped Discipline you have learned that costs 1-3 SP. Any Conditions excluding SP cost still apply. This Discipline may target a different figure."
    },
    {
      "name": "The Pessimist",
      "discipline": "Assemblage",
      "tier": 3,
      "description": "Passive: When an opponent within SOI fails a Conviction Check by 3 or more, Inflict Condemn. (\"With the choice of two evils, I'll take both.\")"
    },
    {
      "name": "Felled Afterlife",
      "discipline": "Assemblage",
      "tier": 4,
      "description": "Passive: When an opponent within your SOI is Defeated, this card Gains 1 Energy token. (Limit 2). When determining the Force of a Spell, if you have 2 Energy tokens on this card, Gain +1 to the Force. Per Encounter: Discard 2 Energy tokens from this card to Gain 2 Enslaved Spirits."
    },
    {
      "name": "Soul Bond",
      "discipline": "Assemblage",
      "tier": 4,
      "description": "Passive: When you use the Discipline Summoning, Gain 1 additional Summon token. Whenever a Loyal Esper you Summoned spends SP to make any Action or Ability, they may spend SP that you have available instead of their own. If either you or your Loyal Espers Gain or lose a Positive Effect, you each also Gain or lose that Effect."
    },
    {
      "name": "The Tower Reversed",
      "discipline": "Assemblage",
      "tier": 4,
      "description": "Exhaust: Cast a Spell 6. Deal 3 Magic DMG for each Effect the target has. Then, Inflict Darkness, Disease, and Paralyze."
    },
    {
      "name": "Corrosive Ideal",
      "discipline": "Cruor",
      "tier": 1,
